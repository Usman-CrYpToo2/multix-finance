# Copy to .env and fill in before running any hyperlane CLI command.
# Never commit the real .env - it holds a live private key.

# Funded deployer/test wallet, used on BOTH Somnia testnet and Ethereum Sepolia.
HYP_KEY=

# Optional: override RPC URLs if you don't want to rely on the public
# hyperlane-registry defaults for somniatestnet / sepolia.
# SOMNIA_TESTNET_RPC_URL=
# SEPOLIA_RPC_URL=
